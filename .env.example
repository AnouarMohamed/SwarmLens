# ── Mode ─────────────────────────────────────────────────────────────────────
APP_MODE=demo                          # dev | demo | prod
DEFAULT_CLUSTER_NAME=primary

# ── Docker connection ─────────────────────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_HOST=tcp://manager:2376       # for remote manager
# DOCKER_TLS_VERIFY=true
# DOCKER_CERT_PATH=/path/to/certs      # dir with ca.pem, cert.pem, key.pem

# ── Persistence ───────────────────────────────────────────────────────────────
DATABASE_URL=                          # postgres://user:pass@postgres:5432/swarmlens?sslmode=disable
# DATABASE_URL_FILE=                   # /run/secrets/swarmlens_database_url

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_ENABLED=false
AUTH_TOKENS=                           # viewer:viewer:token1,operator:operator:token2,admin:admin:token3
AUTH_TOKENS_FILE=                      # /run/secrets/swarmlens_auth_tokens
AUTH_PROVIDER=                         # oidc
AUTH_OIDC_ISSUER_URL=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_CLIENT_SECRET_FILE=          # /run/secrets/swarmlens_oidc_client_secret
AUTH_OIDC_REDIRECT_URL=
AUTH_OIDC_SCOPES=openid,profile,email,groups
AUTH_OIDC_USERNAME_CLAIM=
AUTH_OIDC_ROLE_CLAIM=
AUTH_OIDC_GROUPS_CLAIM=groups
AUTH_OIDC_VIEWER_GROUPS=
AUTH_OIDC_OPERATOR_GROUPS=
AUTH_OIDC_ADMIN_GROUPS=
AUTH_TRUSTED_PROXY_CIDRS=
CORS_ALLOW_ORIGINS=                    # https://ops.example.com,https://admin.example.com
SESSION_COOKIE_NAME=swarmlens_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=12

# ── Write gate ────────────────────────────────────────────────────────────────
WRITE_ACTIONS_ENABLED=false            # must be explicit opt-in
WRITE_APPROVAL_REQUIRED=true           # four-eyes for high-risk ops in prod
ACTION_SAFE_SCALE_DELTA=2
LIVE_ACTION_POLICY=read_only_dry_run

# ── Diagnostics ───────────────────────────────────────────────────────────────
DIAGNOSTICS_SCHEDULE=60                # seconds between auto-runs (0 = manual only)
SNAPSHOT_STALE_SECONDS=45

# ── Predictor (optional) ──────────────────────────────────────────────────────
PREDICTOR_BASE_URL=                    # http://predictor:8001
PREDICTOR_SHARED_SECRET=
PREDICTOR_SHARED_SECRET_FILE=          # /run/secrets/swarmlens_predictor_secret

# ── Assistant (optional) ──────────────────────────────────────────────────────
ASSISTANT_PROVIDER=none                # openai | none
ASSISTANT_API_BASE_URL=                # https://api.openai.com/v1 or http://localhost:11434/v1
ASSISTANT_API_KEY=
ASSISTANT_API_KEY_FILE=                # /run/secrets/swarmlens_assistant_api_key
ASSISTANT_MODEL=                       # gpt-4o | llama3.2 | etc
ASSISTANT_RAG_ENABLED=true

# ── Local Postgres for docker-compose ─────────────────────────────────────────
POSTGRES_DB=swarmlens
POSTGRES_USER=swarmlens
POSTGRES_PASSWORD=swarmlens

# Grafana frontend embeds (optional)
VITE_GRAFANA_URL=                      # https://grafana.example.com
VITE_GRAFANA_DASHBOARD_UID=            # e.g. swarmlens-main
VITE_GRAFANA_ORG_ID=1
VITE_GRAFANA_THEME=dark
VITE_GRAFANA_FROM=now-6h
VITE_GRAFANA_TO=now
VITE_GRAFANA_REFRESH=30s
VITE_GRAFANA_KIOSK=tv
VITE_GRAFANA_DATASOURCE=Prometheus

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=swarmlens-backend
OTEL_TRACES_SAMPLE_RATIO=1

# ── Alerting ──────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERTMANAGER_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
